# ⚠️ 복사해서 .env.local로 사용. git 커밋 금지. 전부 서버 전용 — NEXT_PUBLIC_ 절대 금지.

# Gemini (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# 검색 grounding 전용 모델 — 무료 티어에서 3.5-flash는 grounding 쿼터가 없어 분리
GEMINI_GROUNDING_MODEL=gemini-2.5-flash
# 쿼터 소진 시 대체용 예비 키 (미설정 시 GEMINI_API_KEY만 사용)
GEMINI_API_KEY_2=

# Unsplash (https://unsplash.com/oauth/applications)
UNSPLASH_ACCESS_KEY=

# Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=

# 이미지 실제 생성 (Step 19) — NVIDIA NIM (https://build.nvidia.com)
# 미설정 시 이미지 힌트는 프롬프트 표출만 (자동 폴백, 에러 아님)
NVIDIA_API_KEY=
# 기본 모델: black-forest-labs/flux.1-dev — 교체할 때만 설정 (schnell은 콜드스타트 504 잦음)
# NVIDIA_IMAGE_MODEL=
